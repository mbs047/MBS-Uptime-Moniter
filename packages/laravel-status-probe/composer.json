{
    "name": "mbs047/laravel-status-probe",
    "description": "Configurable health and metadata endpoints for Laravel apps monitored by MBS Uptime Monitor.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Mbs047\\LaravelStatusProbe\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mbs047\\LaravelStatusProbe\\StatusProbeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
